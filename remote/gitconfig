# Git config for remote VMs — no personal identity baked in.
# Set your identity per-VM:
#   git config --global user.name "Your Name"
#   git config --global user.email "you@example.com"
# Or add them to ~/.gitconfig.local (sourced below).

[core]
	excludesfile = ~/.gitignore_global
	editor = vim
[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "status"]
	changed = green
	untracked = cyan
	added = yellow
[color "diff"]
	new = green bold
	frag = magenta bold
	meta = yellow bold
	old = red bold
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[include]
	path = ~/.gitconfig.local
