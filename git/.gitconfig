
[core]
	excludesfile = ~/.gitignore_global
	editor = vim
[diff]
	push = matching
[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "status"]
	changed = green
	untracked = cyan
	added = yellow
[color "diff"]
	new = green bold
	frag = magenta bold
	meta = yellow bold
	old = red bold
[init]
	defaultBranch = main
[user]
	name = bryan kennedy
	email = bryan@mysteryexperience.com
[push]
	autoSetupRemote = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
