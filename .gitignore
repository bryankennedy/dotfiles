# MacOS
.DS_Store

# Karabiner
karabiner/.config/karabiner/automatic_backups/

# Claude Code session-specific permissions (auto-generated, not version controlled)
.claude/settings.local.json

# Antigravity CLI — runtime and machine-specific data (not portable across machines)
# Keep settings.json and keybindings.json (user config); ignore everything else
gemini/.gemini/antigravity-cli/*
!gemini/.gemini/antigravity-cli/settings.json
!gemini/.gemini/antigravity-cli/keybindings.json

# Antigravity CLI — project session data (UUID-named, auto-generated per session)
gemini/.gemini/config/projects/

# Antigravity CLI — migration marker (auto-generated one-time flag)
gemini/.gemini/config/.migrated

# Cursor — Cloudflare plugin skills auto-installed by the app into the stowed
# ~/.cursor/skills dir; machine-generated and re-installed/updated by Cursor, so
# not version controlled (hand-authored skills like smart-commit stay tracked)
cursor/.cursor/skills/agents-sdk/
cursor/.cursor/skills/cloudflare/
cursor/.cursor/skills/cloudflare-email-service/
cursor/.cursor/skills/cloudflare-one/
cursor/.cursor/skills/cloudflare-one-migrations/
cursor/.cursor/skills/durable-objects/
cursor/.cursor/skills/sandbox-sdk/
cursor/.cursor/skills/turnstile-spin/
cursor/.cursor/skills/web-perf/
cursor/.cursor/skills/workers-best-practices/
cursor/.cursor/skills/wrangler/

# Gemini/Antigravity — skills auto-installed by the app into the stowed
# ~/.gemini dirs; machine-generated, not portable, so not version controlled
gemini/.gemini/skills/
gemini/.gemini/antigravity/skills/

# herdr — runtime logs, sockets, and session state herdr writes into the stowed
# ~/.config/herdr dir; machine-specific, not version controlled (keep config.toml)
herdr/.config/herdr/*
!herdr/.config/herdr/config.toml
