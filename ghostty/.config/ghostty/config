# Ghostty Configuration

# Run tmux by default
command = /opt/homebrew/bin/tmux new-session -A -s main

# After lots of trial and error, I always come back to Monaco
font-family = "Monaco"
font-size = 14

# Personal color theme
theme = crispy

window-padding-x = 50
window-padding-y = 50
macos-titlebar-style = tabs

# Dock / app switcher icon: ICNS from this repo at ghostty/.config/ghostty/Ghostty.icns (stow → ~/.config/ghostty/).
macos-icon = custom
macos-custom-icon = ~/.config/ghostty/Ghostty.icns
# I like this option but don't want to use it right now. Keeping it here for reference.
# macos-icon = holographic

background-opacity = 0.96
unfocused-split-opacity = 0.5
cursor-style = block
shell-integration = detect

# Make everything look a litle fuzzy and glowing. Fun sometimes, but not right now.
# custom-shader = ./shaders/bloom.glsl

# Red tracer path for cursor jumps
custom-shader = ./shaders/cursor_blaze.glsl

# Notify only when the window is not in focus
notify-on-command-finish = unfocused

# Enable desktop notifications (and optionally the system bell)
notify-on-command-finish-action = notify,bell

# How long a command must run before it triggers a notification
notify-on-command-finish-after = 10s

# Flash on bell
bell-features = attention
