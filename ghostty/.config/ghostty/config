# Ghostty Configuration

command = /bin/zsh
font-family = "Monaco"
font-size = 14
# --- Popular Themes (2024/2025 Top Picks) ---
# theme = catppuccin-mocha      # (Current - Excellent contrast)
# theme = Dracula               # (Classic Vampire Dark theme)
# theme = tokyonight            # (Calm blue/purple night theme)
# theme = Nord                  # (Arctic, cool bluish theme)
# theme = GruvboxDark           # (Retro earthy tones)
# theme = OneHalfDark           # (Clean, balanced Atom-like theme)
# theme = Snazzy                # (Elegant with bright colors)
theme = crispy
# theme = rose-pine             # (Soothing pastel palette)
# theme = kanagawa              # (Inspired by Japanese paintings)
# theme = monokai_pro           # (Professional, high contrast)

# --- Light Themes ---
# theme = catppuccin-latte      # (Warm light theme)
# theme = OneHalfLight          # (Clean light theme)
# theme = Builtin Solarized Light
window-padding-x = 50
window-padding-y = 50
macos-titlebar-style = tabs

# Dock / app switcher icon: ICNS from this repo at ghostty/.config/ghostty/Ghostty.icns (stow → ~/.config/ghostty/).
macos-icon = custom
macos-custom-icon = ~/.config/ghostty/Ghostty.icns
# I like this option but don't want to use it right now.
# macos-icon = holographic

background-opacity = 0.96
unfocused-split-opacity = 0.5
cursor-style = block
shell-integration = detect

# Make everything look a litle fuzzy and glowing. Fun sometimes.
# custom-shader = ./shaders/bloom.glsl

# Red tracer path for cursor jumps
custom-shader = ./shaders/cursor_blaze.glsl
# notify-on-command-finish = unfocused